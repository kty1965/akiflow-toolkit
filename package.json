{
  "name": "akiflow-toolkit",
  "version": "1.0.4",
  "description": "Unofficial Akiflow CLI + MCP server toolkit for AI-powered task management",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "af": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build ./src/index.ts --outdir dist --target node && bun run scripts/post-build.ts",
    "build:binary": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64 && bun run build:linux-arm64",
    "build:darwin-arm64": "bun build --compile --minify src/index.ts --outfile dist/af-darwin-arm64",
    "build:darwin-x64": "bun build --compile --minify --target=bun-darwin-x64 src/index.ts --outfile dist/af-darwin-x64",
    "build:linux-x64": "bun build --compile --minify --target=bun-linux-x64 src/index.ts --outfile dist/af-linux-x64",
    "build:linux-arm64": "bun build --compile --minify --target=bun-linux-arm64 src/index.ts --outfile dist/af-linux-arm64",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check src/",
    "lint:fix": "bunx @biomejs/biome check --write src/",
    "commitlint": "bunx --bun commitlint --edit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chrono-node": "^2.9.0",
    "citty": "^0.2.1",
    "rrule": "^2.8.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/bun": "latest",
    "semantic-release": "^24.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kty1965/akiflow-toolkit.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "akiflow",
    "cli",
    "mcp",
    "task-management",
    "ai",
    "claude-code",
    "unofficial"
  ],
  "license": "MIT"
}
